{
  "name": "artist-reference-collection",
  "version": "0.1.8",
  "description": "ARC — десктопное приложение для организации визуальных материалов",
  "main": "main/index.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "test": "vitest run",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json",
    "verify:renderer-ui": "npm run build:renderer && vitest run renderer/src/__tests__/rendererSmoke.test.tsx",
    "icons": "node scripts/generate-icon.mjs",
    "predist:win": "npm run icons",
    "predist:mac": "npm run icons",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 --x64 --publish never",
    "publish:win": "npm run build && electron-builder --win --publish always",
    "renderer:dev": "vite --config renderer/vite.config.ts",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3,sharp,node-llama-cpp",
    "electron:dev": "npm run build:main && npm run build:preload && npm run rebuild:native && wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k \"npm run renderer:dev\" \"npm run electron:dev\"",
    "verify:ai-models": "node scripts/verify-ai-models.mjs",
    "thumbs:regenerate": "npm run build:main && cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/regenerate-thumbs.mjs",
    "postinstall": "electron-rebuild -f -w better-sqlite3,sharp,node-llama-cpp"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "private": true,
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^2.1.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^3.2.6",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.8.9",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "gsap": "^3.15.0",
    "konva": "^10.3.0",
    "node-llama-cpp": "^3.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-konva": "^19.2.3",
    "react-router-dom": "^7.14.2",
    "sharp": "^0.34.5"
  }
}
