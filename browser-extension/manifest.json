{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "version": "0.1.19",
  "icons": {
    "16": "icons/icon-32.png",
    "48": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_extensionName__"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["contextMenus", "storage", "alarms", "tabs"],
  "host_permissions": [
    "http://127.0.0.1:47896/*",
    "http://localhost:47896/*",
    "https://*.pinterest.com/*",
    "https://pinterest.com/*",
    "https://*.pinterest.ru/*",
    "https://pinterest.ru/*",
    "https://*.instagram.com/*",
    "https://instagram.com/*",
    "https://*.artstation.com/*",
    "https://artstation.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/sites/urlUtils.js",
        "lib/sites/generic.js",
        "lib/sites/pinterest.js",
        "lib/sites/youtube.js",
        "lib/artstation/projectParseBridge.js",
        "lib/sites/artstation.js",
        "lib/instagram/mediaFilter.js",
        "lib/instagram/postParseBridge.js",
        "lib/instagram/mediaApiBridge.js",
        "lib/sites/instagram.js",
        "lib/sites/registry.js",
        "lib/pinterest/board.js",
        "lib/instagram/saved.js",
        "lib/artstation/album.js",
        "lib/sites/resolveSave.js",
        "lib/constants.js",
        "lib/pageModal.js",
        "content.js"
      ],
      "css": ["arc-modal.css"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
