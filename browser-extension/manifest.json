{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "description": "__MSG_extensionDescription__",
  "default_locale": "en",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-32.png",
    "48": "icons/icon-64.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_extensionName__"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["contextMenus", "storage", "alarms"],
  "host_permissions": ["http://127.0.0.1:47896/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/pageToast.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ]
}
